// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SheetType {
  STANDARD
  SCRAP
}

enum MovementType {
  ENTRY
  EXIT
}

enum ProfileType {
  SQUARE // Quadrado - altura = largura
  RECTANGULAR // Retangular - altura ≠ largura
  ROUND // Redondo - altura = largura (diâmetro)
  OBLONG // Oblongo - altura ≠ largura
  ANGLE // Cantoneira - altura = largura
  U_CHANNEL // Perfil U - altura ≠ largura
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role        UserRole @default(OPERATOR)
  permissions Json     @default("{}")

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("users")
}

model Material {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  sheets   Sheet[]
  profiles Profile[]

  @@map("materials")
}

model Sheet {
  id              String  @id @default(uuid())
  sku             String
  width           Float
  height          Float
  thickness       Float
  quantity        Int     @default(0)
  price           Float?  @default(0)
  storageLocation String? @map("storage_location")

  type SheetType @default(STANDARD)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  materialId String   @map("material_id")
  material   Material @relation(fields: [materialId], references: [id])

  clientId String? @map("client_id")
  client   Client? @relation(fields: [clientId], references: [id])

  movements InventoryMovement[]

  @@unique([materialId, width, height, thickness, clientId, type])
  @@map("sheets")
}

model Client {
  id       String  @id @default(uuid())
  name     String
  document String  @unique // CPF ou CNPJ
  phone    String?
  email    String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  sheets   Sheet[] // um client pode ter várias chapas
  profiles Profile[] // um client pode ter vários perfis

  @@map("clients")
}

model InventoryMovement {
  id          String       @id @default(uuid())
  type        MovementType
  quantity    Int
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")

  sheetId String? @map("sheet_id")
  sheet   Sheet?  @relation(fields: [sheetId], references: [id])

  profileId String?  @map("profile_id")
  profile   Profile? @relation(fields: [profileId], references: [id])

  @@map("inventory_movements")
}

model Profile {
  id              String      @id @default(uuid())
  sku             String
  profileType     ProfileType @map("profile_type")
  width           Float
  height          Float
  length          Float
  thickness       Float
  quantity        Int         @default(0)
  price           Float?      @default(0)
  storageLocation String?     @map("storage_location")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  materialId String   @map("material_id")
  material   Material @relation(fields: [materialId], references: [id])

  clientId String? @map("client_id")
  client   Client? @relation(fields: [clientId], references: [id])

  movements InventoryMovement[]

  @@unique([materialId, profileType, width, height, length, thickness, clientId])
  @@map("profiles")
}
